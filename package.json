{
  "name": "bybit-official-trading-server",
  "version": "2.1.5",
  "publishConfig": {
    "access": "public"
  },
  "description": "Bybit trading MCP server — exposes Bybit REST and WebSocket APIs as MCP tools",
  "type": "module",
  "main": "dist/index.js",
  "license": "MIT",
  "keywords": [
    "bybit",
    "trading",
    "mcp",
    "server",
    "crypto",
    "exchange",
    "api"
  ],
  "bin": {
    "trading-mcp": "dist/index.js",
    "bybit-official-trading-server": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bybit-exchange/trading-mcp.git"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "codex:mcp:install": "powershell -ExecutionPolicy Bypass -File scripts/install-codex-mcp.ps1",
    "codex:mcp:smoke": "powershell -ExecutionPolicy Bypass -File scripts/smoke-codex-mcp.ps1",
    "codex:mcp:smoke:mexc": "powershell -ExecutionPolicy Bypass -File scripts/smoke-codex-mcp-mexc.ps1",
    "codex:mcp:smoke:linux": "bash scripts/smoke-codex-mcp.sh",
    "codex:mcp:smoke:mexc:linux": "bash scripts/smoke-codex-mcp-mexc.sh",
    "codex:mcp:uninstall": "powershell -ExecutionPolicy Bypass -File scripts/remove-codex-mcp.ps1",
    "codex:session": "powershell -ExecutionPolicy Bypass -File scripts/start-codex-with-mcp.ps1",
    "codex:session:linux": "bash scripts/start-codex-with-mcp.sh",
    "dev": "node --env-file=.env --import tsx/esm src/index.ts",
    "mexc:start": "node --env-file=.env --import tsx/esm src/mexc.ts",
    "generate": "node scripts/generate-tools.mjs generate",
    "codegen:bootstrap": "node scripts/generate-tools.mjs bootstrap",
    "codegen:openai-functions": "npm --prefix apps/openai-function-tools-adapter run codegen",
    "smoke:bybit": "node --import tsx/esm scripts/bybit-smoke.ts",
    "smoke:mexc": "node --env-file=.env --import tsx/esm scripts/mexc-smoke.ts",
    "smoke:mexc:readonly": "node --env-file=.env --import tsx/esm scripts/mexc-readonly-smoke.ts",
    "smoke:mexc:write": "node --env-file=.env --import tsx/esm scripts/mexc-write-smoke.ts",
    "smoke:mexc:ws": "node --env-file=.env --import tsx/esm scripts/mexc-ws-smoke.ts",
    "smoke:openai-functions": "npm --prefix apps/openai-function-tools-adapter run live-check",
    "webui:http": "node apps/local-mcp-web-ui/src/server.mjs",
    "webui:start": "node apps/local-mcp-web-ui/src/server.mjs",
    "webui:serve": "node apps/local-mcp-web-ui/src/tailscale-publish.mjs serve",
    "webui:serve:status": "tailscale serve status --json",
    "webui:serve:reset": "tailscale serve reset",
    "webui:funnel": "node apps/local-mcp-web-ui/src/tailscale-publish.mjs funnel",
    "webui:funnel:status": "tailscale funnel status --json",
    "webui:funnel:reset": "tailscale funnel reset",
    "webui:app-server": "powershell -ExecutionPolicy Bypass -File scripts/start-codex-app-server-with-mcp.ps1",
    "webui:app-server:linux": "bash scripts/start-codex-app-server-with-mcp.sh",
    "webui:app-server:smoke": "node apps/local-mcp-web-ui/src/smoke-app-server.mjs",
    "webui:mexc-routing:smoke": "node apps/local-mcp-web-ui/src/smoke-mexc-routing.mjs",
    "webui:smoke": "node apps/local-mcp-web-ui/src/smoke-webui.mjs",
    "typecheck": "tsc --noEmit",
    "verify": "node scripts/verify.mjs",
    "publish-pkg": "bash scripts/publish.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "protobufjs": "^8.5.0",
    "ws": "^8.18.0",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "js-yaml": "^4.1.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.6"
  }
}
